# Yoyo Collection — configuration
# Copy this file to ".env" and fill in what you need. EVERY setting is optional;
# with none set, the app runs fully open (anyone can view and edit) on port 3000.

# ---- Server ----
# HTTP port (the host assigns this on most platforms — leave unset there).
PORT=3000

# Where the SQLite database file and photo uploads live. Point these at a
# persistent disk/volume in production so redeploys don't wipe your collection.
DB_PATH=data/yoyos.db
UPLOAD_DIR=uploads

# ---- Access control (pick at most one model) ----
# Owner login: the public sees a read-only collection; you log in to edit.
# Setting this enables the login button. Recommended for a public showcase.
ADMIN_PASSWORD=

# Make the whole app read-only (no editing at all, no login).
# Accepts: 1 / true / yes
READ_ONLY=

# Public demo mode: login still works (so visitors can see the owner view), but
# EVERY data-changing request is refused — no edits, deletes, photo uploads, or
# restores. Also adds noindex so the demo stays out of search. Pair with
# ADMIN_PASSWORD (e.g. "demo") and RATE_LIMIT_MAX. Accepts: 1 / true / yes
DEMO_MODE=

# Fully-private instance: HTTP Basic Auth over the ENTIRE app. Set BOTH to
# require a username + password just to view anything.
AUTH_USER=
AUTH_PASS=

# Signs login session tokens. If unset it's derived from ADMIN_PASSWORD, which
# is fine for a single instance; set an explicit random string if you prefer.
SESSION_SECRET=

# Allow embedding the app in an <iframe> on this origin, e.g. https://yoursite.com
FRAME_ANCESTORS=

# Rate limiting (per client IP). Off unless RATE_LIMIT_MAX is set. Useful for a
# public demo so a bot can't hammer it. A normal page load is only a handful of
# requests, so 120/min is generous for humans but stops abuse.
RATE_LIMIT_MAX=
RATE_LIMIT_WINDOW_MS=60000

# ---- Carrier tracking (optional) ----
# Enables the "Query ETA" button on the Arrivals page. Add only the carriers you
# use; each needs PRODUCTION OAuth credentials from that carrier's developer site.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
